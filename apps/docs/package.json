{
  "name": "libravel-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "bun run build:registry && bun run build:themes && bun run next build",
    "dev": "bun run next dev --turbo",
    "dev:stable": "NODE_OPTIONS='--max-old-space-size=2048' bun run next dev --turbo",
    "dev:lite": "NODE_OPTIONS='--max-old-space-size=512' bun run next dev",
    "dev:all": "bun run build:registry && bun run build:themes && bun run next dev --turbo",
    "start": "bun run next start",
    "postinstall": "bun x fumadocs-mdx",
    "lint": "bun run eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "build:registry": "bun x tsx src/scripts/build-registry.ts",
    "build:themes": "bun x tsx src/scripts/build-themes.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@types/acorn": "^4.0.6",
    "@vercel/speed-insights": "^1.3.1",
    "acorn": "^8.16.0",
    "babel-plugin-macros": "^3.1.0",
    "fumadocs-core": "15.7.13",
    "fumadocs-docgen": "^3.0.8",
    "fumadocs-mdx": "11.10.1",
    "fumadocs-typescript": "^4.0.14",
    "fumadocs-ui": "15.7.13",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.544.0",
    "motion": "^12.34.3",
    "next": "^16.1.1",
    "ogl": "^1.0.11",
    "oxc-transform": "^0.99.0",
    "react": "^19.2.4",
    "react-aria-components": "^1.15.1",
    "react-docgen-typescript": "^2.4.0",
    "react-dom": "^19.2.4",
    "react-element-to-jsx-string": "^17.0.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "sucrase": "^3.35.1",
    "tailwindcss-react-aria-components": "^2.0.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "eslint-config-next": "15.5.3",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
